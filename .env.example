# Estimation Tools — environment variable NAMES ONLY. Never put real values in
# this file. Real values live in:
#   Vercel   → Project → Settings → Environment Variables (server-side)
#   Local    → .env.local (gitignored — verified) for `vercel dev`
# The service-role key and Gemini key must NEVER appear in frontend code,
# committed files, logs, or test snapshots.

# ── Hosted AI extraction (server-side only) ─────────────────────────────
# Google Gemini is the MASTER agent (orchestrates + audits the sub-agents).
GEMINI_API_KEY=
# Exact model id (pinned default in code; never changed silently).
GEMINI_MODEL=
# Optional second Gemini model for the deterministic cross-check pass.
GEMINI_VERIFY_MODEL=

# ── NVIDIA sub-agent pool (server-side only; build.nvidia.com free tier) ─
# Up to three keys, one per NVIDIA account — each has its own rate budget.
# Model→key routing lives in api/_lib/extraction/nvidia-pool.mjs.
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
# Engine override: unset = agent team runs whenever NVIDIA keys exist;
# set to 'off' to force the direct Gemini-only extractor.
AGENT_TEAM=

# ── Commerce / paid downloads (server-side only; ships DISABLED until set) ─
# Store state: unset/false keeps /download/ in "coming soon"; nothing half-works.
COMMERCE_ENABLED=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_TAX_ENABLED=
DOWNLOAD_TOKEN_SECRET=
SITE_URL=
SUPPORT_EMAIL=
LEGAL_SELLER_NAME=
PRODUCT_DISPLAY_NAME=
# Signed-installer delivery (Cloudflare R2 + gateway worker)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
FILES_DOWNLOAD_HOST=
# Restore-by-email (Resend)
RESEND_API_KEY=
MAIL_FROM=

# ── Supabase (server-side only) ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Browser-safe (only once Supabase Auth ships in the frontend) ────────
# The publishable key is designed for browsers but is still never committed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
