# Estimation Tools — environment variable NAMES ONLY. Never put real values
# in this file or commit a real .env. Set production values in:
#   Netlify  → Site configuration → Environment variables
#   GitHub   → Repo → Settings → Secrets and variables → Actions
#   Cloudflare → Worker → Settings → Variables (download gateway only)
#
# Commerce ships DISABLED. The store shows "coming soon" until
# COMMERCE_ENABLED=true AND every required value below is present.

# ── Extraction runtime (Netlify function) ────────────────────────────────
# Google Gemini is the ONLY runtime AI provider.
GEMINI_API_KEY=
# Pin an exact stable model id (no "latest" aliases).
GEMINI_MODEL=

# ── Commerce master switch ───────────────────────────────────────────────
COMMERCE_ENABLED=false

# ── Site identity ────────────────────────────────────────────────────────
# Public origin of the deployed site, e.g. https://www.{ROOT_DOMAIN}
SITE_URL=
PRODUCT_DISPLAY_NAME=
SUPPORT_EMAIL=
LEGAL_SELLER_NAME=

# ── Stripe (server-side only — never shipped to the browser) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Set to "true" once Stripe Tax is configured for the account.
STRIPE_TAX_ENABLED=

# ── Download authorisation ───────────────────────────────────────────────
# HMAC secret for download cookies, restore tokens and gateway claims.
# Generate with: openssl rand -base64 48
DOWNLOAD_TOKEN_SECRET=
# Branded delivery host served by workers/download-gateway,
# e.g. files.{ROOT_DOMAIN}. Leave empty to fall back to presigned R2 URLs.
FILES_DOWNLOAD_HOST=

# ── Cloudflare R2 (private bucket: estimation-tools-releases) ────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Restore-purchase email (Resend) ──────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=

# ── CI-only signing secrets (GitHub Actions, never Netlify) ──────────────
# Azure Trusted Signing (Windows):
#   AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET,
#   AZURE_SIGNING_ENDPOINT, AZURE_SIGNING_ACCOUNT, AZURE_CERT_PROFILE
# Apple Developer ID (macOS):
#   APPLE_ID, APPLE_APP_SPECIFIC_PASSWORD, APPLE_TEAM_ID,
#   CSC_LINK, CSC_KEY_PASSWORD
